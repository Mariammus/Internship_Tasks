ВЫБРАТЬ
	Номенклатура.Ссылка,
	Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель,
	7
ИЗ
	Справочник.Номенклатура КАК Номенклатура
ГДЕ
	Номенклатура.Ссылка В (ВЫБРАТЬ ВТТовары.Товар ИЗ ВТТовары)
	И Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТПапкиСУровнями.Товар) КАК Товар,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТПапкиСУровнями.Папка) КАК Папка,
	ВТПапкиСУровнями.Уровень КАК Уровень
ИЗ
	ВТПапкиСУровнями КАК ВТПапкиСУровнями

УПОРЯДОЧИТЬ ПО
	ВТПапкиСУровнями.Товар,
	Уровень
